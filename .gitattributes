# Ignore native platform folders in language statistics
android/* linguist-documentation
ios/* linguist-documentation
windows/* linguist-documentation
linux/* linguist-documentation
macos/* linguist-documentation
web/* linguist-documentation
# Treat CMake and C++ build files as documentation/vendor
*.cpp linguist-documentation
*.h linguist-documentation
*.cmake linguist-documentation
CMakeLists.txt linguist-documentation
# Ensure Dart is the primary detectable language
*.dart linguist-detectable=true